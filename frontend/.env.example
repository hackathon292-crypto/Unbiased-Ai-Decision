# Copy this file to .env.local (dev) or set in your hosting provider (prod).
# Vite exposes only VITE_* variables to the browser bundle.

# ─── LOCAL DEV ────────────────────────────────────────────────────────────────
# Leave BLANK. Vite will proxy /health, /files, /hiring, /loan, /social,
# /feedback, /insights, /mitigation, /shap and /models to http://localhost:8000
# (see vite.config.ts). Setting a full URL here will bypass the proxy and
# usually trigger CORS errors unless the backend explicitly allows the origin.
VITE_API_BASE_URL=

# ─── PRODUCTION ──────────────────────────────────────────────────────────────
# Already set in netlify.toml [build.environment] — no dashboard config needed.
# Override here only if you rename the Render service:
# VITE_API_BASE_URL=https://quantum-ai-backend.onrender.com
